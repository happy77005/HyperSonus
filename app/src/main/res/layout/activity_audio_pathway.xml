<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#121212"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Audio Processing Path"
            app:titleTextColor="#FFFFFF" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Source Stage -->
            <include
                android:id="@+id/stage_source"
                layout="@layout/item_pathway_stage" />

            <View
                android:layout_width="2dp"
                android:layout_height="24dp"
                android:layout_gravity="center_horizontal"
                android:background="#33FFFFFF" />

            <!-- Decoder Stage -->
            <include
                android:id="@+id/stage_decoder"
                layout="@layout/item_pathway_stage" />

            <View
                android:layout_width="2dp"
                android:layout_height="24dp"
                android:layout_gravity="center_horizontal"
                android:background="#33FFFFFF" />

            <!-- Resampler Stage -->
            <include
                android:id="@+id/stage_resampler"
                layout="@layout/item_pathway_stage" />

            <View
                android:layout_width="2dp"
                android:layout_height="24dp"
                android:layout_gravity="center_horizontal"
                android:background="#33FFFFFF" />

            <!-- DSP Stage -->
            <include
                android:id="@+id/stage_dsp"
                layout="@layout/item_pathway_stage" />

            <View
                android:layout_width="2dp"
                android:layout_height="24dp"
                android:layout_gravity="center_horizontal"
                android:background="#33FFFFFF" />

            <!-- Cross-feed Stage -->
            <LinearLayout
                android:id="@+id/layout_stage_crossfeed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                
                <include
                    android:id="@+id/stage_crossfeed"
                    layout="@layout/item_pathway_stage" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_horizontal"
                    android:background="#33FFFFFF" />
            </LinearLayout>

            <!-- Limiter Stage -->
            <include
                android:id="@+id/stage_limiter"
                layout="@layout/item_pathway_stage" />

            <View
                android:layout_width="2dp"
                android:layout_height="24dp"
                android:layout_gravity="center_horizontal"
                android:background="#33FFFFFF" />

            <!-- Dither Stage -->
            <include
                android:id="@+id/stage_dither"
                layout="@layout/item_pathway_stage" />

            <View
                android:layout_width="2dp"
                android:layout_height="24dp"
                android:layout_gravity="center_horizontal"
                android:background="#33FFFFFF" />

            <!-- Output Stage -->
            <include
                android:id="@+id/stage_output"
                layout="@layout/item_pathway_stage" />

            <!-- Technical Summary Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="16dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="System Statistics"
                        android:textColor="#4CAF50"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="12dp"
                        android:background="#1AFFFFFF" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2">

                        <TextView
                            android:id="@+id/tv_stat_engine"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Engine: Oboe"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_stat_backend"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Backend: AAudio"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_stat_precision"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginTop="8dp"
                            android:text="Precision: 32-bit Float"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_stat_bitperfect"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginTop="8dp"
                            android:text="Bit-Perfect: OFF"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp" />

                    </GridLayout>

                    <TextView
                        android:id="@+id/tv_probed_rates"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Probed Rates: 44.1k, 48k, 96k, 192k"
                        android:textColor="#BDBDBD"
                        android:textSize="10sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:alpha="0.5"
                android:gravity="center"
                android:text="HyperPlay • Bit-Perfect Native Engine"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
